modules = ["nodejs-20", "javascript", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true
integrations = ["javascript_log_in_with_replit:2.0.0", "javascript_anthropic:1.0.0", "javascript_object_storage:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[userenv]

[userenv.shared]
PROD_DB_HOSTS = "empty-scene-ae775drh"

[userenv.development]
CLERK_PUBLISHABLE_KEY = "pk_test_bm90ZWQtYW50LTQyLmNsZXJrLmFjY291bnRzLmRldiQ"
VITE_CLERK_PUBLISHABLE_KEY = "pk_test_bm90ZWQtYW50LTQyLmNsZXJrLmFjY291bnRzLmRldiQ"
CLERK_SECRET_KEY = "sk_test_ko7pDQJAB2gvinwrTxyvrnHmb3ZhUBMruM0fgBrZEa"

